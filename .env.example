# Azure OpenAI (required: endpoint + deployment; key optional with MSI)
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Speech (required: region; key optional with MSI)
# AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# AZURE_SPEECH_VOICE=zh-CN-XiaoxiaoNeural

# Azure Content Understanding (optional, for --use-content-understanding)
# AZURE_CONTENT_UNDERSTANDING_ENDPOINT=
# AZURE_CONTENT_UNDERSTANDING_KEY=
# AZURE_CU_API_VERSION=2025-11-01
# AZURE_CU_MODEL_DEPLOYMENT=gpt-4o

# Azure Document Intelligence (optional, for --use-doc-intel)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Custom ffmpeg binary path (optional)
# FFMPEG_BIN=

# When API key env vars are omitted, the pipeline authenticates via
# DefaultAzureCredential (Managed Identity, Azure CLI, etc.).
# Install the optional dependency:  pip install visual-commentary-pipeline[azure]
